{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "运行 Research Assistant",
      "type": "debugpy",
      "request": "launch",
      "module": "flask",
      "env": {
        "FLASK_APP": "run.py",
        "FLASK_DEBUG": "1"
      },
      "args": ["run", "--host", "127.0.0.1", "--port", "5000"],
      "jinja": true,
      "justMyCode": true
    }
  ]
}

