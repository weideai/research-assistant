APP_ENV=production
DOMAIN=research.example.com
PUBLIC_BASE_URL=https://research.example.com
TRUSTED_HOSTS=research.example.com
USE_PROXY_FIX=true

# Generate each value independently with: openssl rand -base64 48
SECRET_KEY=replace-with-random-value
CREDENTIAL_ENCRYPTION_KEY=replace-with-another-random-value
POSTGRES_PASSWORD=replace-with-strong-database-password

ALLOW_PUBLIC_REGISTRATION=false
BOOTSTRAP_FIRST_USER_ADMIN=false
EXPOSE_DEV_EMAIL_LINKS=false
AI_SETTINGS_ADMIN_ONLY=true
ALLOW_PRIVATE_API_URLS=false
AI_ALLOWED_HOSTS=api.openai.com

MAX_LOGIN_ATTEMPTS=5
LOGIN_LOCK_MINUTES=15
SESSION_HOURS=12
AUTO_CREATE_DB=false

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=research@example.com
SMTP_PASSWORD=replace-with-smtp-password
SMTP_USE_TLS=true
MAIL_FROM=research@example.com

# Optional shared AI fallback. Per-user settings are admin-only in production.
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6-terra

