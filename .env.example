SECRET_KEY=replace-this-with-a-long-random-string
CREDENTIAL_ENCRYPTION_KEY=replace-this-with-a-different-random-string
# Local development address used by `python run.py`.
HOST=127.0.0.1
PORT=5001
# 0 means unlimited. You can set positive MB values when deploying publicly.
MAX_UPLOAD_REQUEST_MB=0
MAX_ATTACHMENT_MB=0
ALLOW_OPEN_LOCAL_FOLDERS=true
# AI connections are configured as encrypted per-account presets in the web UI.

# 可选：实验周报 PowerPoint 运行时。当前 Codex 环境可自动发现。
PRESENTATION_NODE_PATH=
ARTIFACT_TOOL_MODULE=
# GitHub Release 更新检查只提醒，不自动安装。设为 false 可完全关闭联网检查。
UPDATE_CHECK_ENABLED=true
UPDATE_REPOSITORY=weideai/research-assistant
UPDATE_CACHE_HOURS=24
