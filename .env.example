SECRET_KEY=replace-this-with-a-long-random-string
CREDENTIAL_ENCRYPTION_KEY=replace-this-with-a-different-random-string
# 0 means unlimited. You can set positive MB values when deploying publicly.
MAX_UPLOAD_REQUEST_MB=0
MAX_ATTACHMENT_MB=0
ALLOW_OPEN_LOCAL_FOLDERS=true
# Optional: enables AI note organization
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-5.6-terra
